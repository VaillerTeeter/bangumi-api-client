{
  "$schema": "https://unpkg.com/knip@5/schema.json",

  "entry": ["src/index.ts"],

  "project": ["src/**/*.ts"],

  "ignore": [],

  "ignoreDependencies": ["@types/*"],

  "ignoreBinaries": [],

  "includeEntryExports": false,

  "exclude": [],

  "rules": {
    "files": "error",
    "dependencies": "error",
    "devDependencies": "error",
    "optionalPeerDependencies": "error",
    "unlisted": "error",
    "binaries": "error",
    "unresolved": "error",
    "exports": "error",
    "nsExports": "error",
    "classMembers": "error",
    "nsClassMembers": "error",
    "types": "error",
    "nsTypes": "error",
    "enumMembers": "error",
    "duplicates": "error"
  }
}
