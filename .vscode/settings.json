{
  // GitHub Copilot 工具审批策略
  // chat.tools.autoApprove 留空 = 所有工具操作均需手动确认（默认行为）
  "chat.tools.autoApprove": [
    // 终端命令仅批准精确匹配；不使用通配符，避免通过重定向、链式执行等方式绕过审批
    "run_in_terminal:cd",
    "run_in_terminal:ls",
    "run_in_terminal:which",
    "run_in_terminal:pwd",
    "run_in_terminal:head",
    "run_in_terminal:tail",
    "run_in_terminal:wc",
    "run_in_terminal:du",
    "run_in_terminal:df",
    // 终端只读命令 — git
    "run_in_terminal:git log",
    "run_in_terminal:git diff",
    "run_in_terminal:git status",
    // git branch 只批准精确列出操作（不加通配符，避免 -v -d 等删除命令被误批）
    "run_in_terminal:git branch",
    "run_in_terminal:git branch -v",
    "run_in_terminal:git branch -a",
    "run_in_terminal:git branch -r",
    "run_in_terminal:git branch --list",
    "run_in_terminal:git remote",
    "run_in_terminal:git show",
    "run_in_terminal:git stash list",
    // git tag 只批准列出操作
    "run_in_terminal:git tag",
    "run_in_terminal:git tag -l",
    "run_in_terminal:git tag --list",
    // 终端只读命令 — Node / npm
    "run_in_terminal:node --version",
    "run_in_terminal:npm list",
    "run_in_terminal:npm outdated",
    "run_in_terminal:npx tsc --noEmit",
    // GitHub MCP — 只读类（查询不修改）
    "mcp_github_list_issues",
    "mcp_github_get_issue",
    "mcp_github_search_issues",
    "mcp_github_list_pull_requests",
    "mcp_github_get_pull_request",
    "mcp_github_get_pull_request_files",
    "mcp_github_get_pull_request_status",
    "mcp_github_get_pull_request_reviews",
    "mcp_github_get_pull_request_comments",
    "mcp_github_get_file_contents",
    "mcp_github_list_commits",
    "mcp_github_search_repositories",
    "mcp_github_search_code",
    "mcp_github_search_users"
    // ⚠️ 写操作（create / update / merge / push）故意不加，保持手动确认
  ],

  // Agent 模式单次会话最大自动请求次数（当前设为 1000，允许单次会话连续执行多个工具调用；若设为 1，则每次工具调用后都必须停下等待用户确认）
  "chat.agent.maxRequests": 1000,

  // 显式声明远程 JSON Schema，避免 VS Code JSON 语言服务器报"不受信任"警告
  "json.schemas": [
    {
      "url": "https://unpkg.com/knip@5/schema.json",
      "fileMatch": [".lintrc/frontend/knip.json"]
    },
    {
      "url": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/packages/cspell-types/cspell.schema.json",
      "fileMatch": [".lintrc/general/cspell.json"]
    }
  ],

  // cSpell：从 .lintrc/general/cspell.json 导入词表（CI 的唯一权威来源）
  // VS Code 扩展会合并导入配置中的 words / ignoreWords / flagWords，
  // 无需在此重复维护词表；CI 通过 --config 显式传参，两者共用同一份配置。
  "cSpell.import": ["./.lintrc/general/cspell.json"],

  // 防止 cSpell 对 cspell.json 文件本身做拼写检查
  "cSpell.ignorePaths": [
    ".lintrc/general/cspell.json",
  ]
}
