  "overrides": [
    {
      "filename": "**/*.ts",
      "words": [],
      "dictionaries": ["typescript", "node", "npm"]
    },
    {
      "filename": "**/*.{js,jsx,tsx}",
      "dictionaries": ["typescript", "node", "npm"]
    },
    {
      "filename": "**/*.py",
      "dictionaries": ["python"]
    },
    {
      "filename": "**/*.go",
      "dictionaries": ["go"]
    },
    {
      "filename": "**/*.rb",
      "dictionaries": ["ruby"]
    },
    {
      "filename": "**/*.java",
      "dictionaries": ["java"]
    },
    {
      "filename": "**/*.php",
      "dictionaries": ["php"]
    },
    {
      "filename": "**/*.{yaml,yml}",
      "words": [
        "kubernetes",
        "kubectl",
        "configmap",
        "kubeconfig",
        "ingress",
        "daemonset",
        "statefulset",
        "namespace",
        "pvc",
        "svc"
      ]
    },
    {
      "filename": "**/*.{tf,tfvars}",
      "dictionaries": ["terraform", "aws"]
    },
    {
      "filename": "**/*.{md,mdx}",
      "words": []
    },
    {
      "filename": "**/README.md",
      "flagWords": []
    },
    {
      "filename": "**/*.sql",
      "dictionaries": ["sql"]
    },
    {
      "filename": "Dockerfile*",
      "dictionaries": ["docker", "bash"]
    }
  ],

  "enableGlobDot": true,
  "useGitignore": true,
  "reportUnknownWords": true,
  "maxNumberOfProblems": 50,
  "minWordLength": 4
}
