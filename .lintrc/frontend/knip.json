{
  "$schema": "https://unpkg.com/knip@5/schema.json",

  "entry": [
    "src/index.{js,ts,jsx,tsx}",
    "src/main.{js,ts,jsx,tsx}",
    "src/app.{js,ts,jsx,tsx}",
    "src/server.{js,ts}",
    "src/pages/**/*.{js,ts,jsx,tsx}",
    "src/app/**/{page,layout,loading,error,not-found}.{js,ts,jsx,tsx}",
    "src/routes/**/*.{js,ts}",
    "bin/**/*.{js,ts}",
    "scripts/**/*.{js,ts}"
  ],

  "project": ["src/**/*.{js,ts,jsx,tsx}", "lib/**/*.{js,ts}", "utils/**/*.{js,ts}"],

  "ignore": [
    "**/*.d.ts",
    "**/*.test.{js,ts,jsx,tsx}",
    "**/*.spec.{js,ts,jsx,tsx}",
    "**/__tests__/**",
    "**/__mocks__/**",
    "node_modules/**",
    "dist/**",
    "build/**",
    ".next/**",
    ".nuxt/**",
    "coverage/**",
    "*.config.{js,ts,mjs,cjs}",
    "vite.config.*",
    "vitest.config.*",
    "jest.config.*",
    "webpack.config.*",
    "rollup.config.*",
    "eslint.config.*",
    "prettier.config.*",
    "tailwind.config.*",
    "postcss.config.*",
    ".lintrc/**",
    "src/generated/**"
  ],

  "ignoreDependencies": ["@hey-api/client-fetch", "tsx"],

  "ignoreBinaries": ["commitlint", "cspell", "eslint", "prettier", "stylelint"],

  "exclude": [],

  "rules": {
    "files": "error",
    "dependencies": "error",
    "devDependencies": "error",
    "optionalPeerDependencies": "error",
    "unlisted": "error",
    "binaries": "error",
    "unresolved": "error",
    "exports": "error",
    "nsExports": "error",
    "classMembers": "error",
    "types": "error",
    "nsTypes": "error",
    "enumMembers": "error",
    "duplicates": "error"
  },

  "workspaces": {
    ".": {
      "entry": ["src/index.{js,ts,jsx,tsx}", "src/main.{js,ts,jsx,tsx}"]
    },
    "packages/*": {
      "entry": ["src/index.{js,ts,jsx,tsx}", "{src,lib}/index.{js,ts}"]
    },
    "apps/*": {
      "entry": ["src/index.{js,ts,jsx,tsx}", "src/main.{js,ts,jsx,tsx}", "src/app.{js,ts,jsx,tsx}"]
    }
  }
}
