{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/packages/cspell-types/cspell.schema.json",
  "version": "0.2",
  "language": "en",

  "words": [
    "biome",
    "checkov",
    "commitlint",
    "commitlintrc",
    "conventionalcommits",
    "cspell",
    "yamllint",
    "gitleaks",
    "sonarjs",
    "jsdoc",
    "lintrc",
    "gitignore",
    "precommit",
    "yaml",
    "toml",
    "jsonc",
    "monorepo",
    "codebase",
    "configs",
    "nonobvious",
    "unawaited"
  ],

  "flagWords": [
    "hte",
    "teh",
    "recieve",
    "occured",
    "doesnt",
    "cant",
    "dont",
    "couldnt",
    "shouldnt",
    "wont",
    "wouldnt",
    "isnt",
    "wasnt",
    "werent",
    "arent",
    "havent",
    "hasnt",
    "hadnt",
    "neednt"
  ],

  "dictionaries": [
    "en_US",
    "companies",
    "softwareTerms",
    "misc",
    "filetypes",
    "typescript",
    "node",
    "npm",
    "bash",
    "git",
    "markdown"
  ],

  "ignorePaths": [
    "yarn.lock",
    "package-lock.json",
    "LICENSE"
  ],

  "overrides": [
    {
      "filename": "**/*.ts",
      "dictionaries": ["typescript", "node", "npm"]
    },
    {
      "filename": "**/*.{yaml,yml}",
      "words": []
    },
    {
      "filename": "**/*.{md,mdx}",
      "words": []
    },
    {
      "filename": "**/README.md",
      "flagWords": []
    }
  ],

  "enableGlobDot": true,
  "useGitignore": true,
  "reportUnknownWords": true,
  "maxNumberOfProblems": 50,
  "minWordLength": 4
}
